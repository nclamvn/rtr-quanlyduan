# ═══════════════════════════════════════════════════
# RtR Control Tower — Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════════════

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# App URL (used in email templates)
VITE_APP_URL=http://localhost:5173

# ─── RTR Auth Gateway (optional — omit for Supabase-only dev mode) ───
# When set, PM uses Gateway for authentication instead of Supabase Auth.
# VITE_AUTH_URL=https://auth.rtrobotics.com

# ─── Edge Function secrets (set in Supabase Dashboard) ───
# These are NOT used by the frontend — set them via:
# Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# RESEND_API_KEY=re_xxxxx
# APP_URL=https://rtr-control.vercel.app
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key
# JWT_SECRET=<same-as-auth-gateway>
# SUPABASE_JWT_SECRET=<supabase-jwt-secret-from-dashboard>
